{
  "$schema": "https://charm.land/crush.json",
  "models": {
    "large": {
      "model": "glm-5.1",
      "provider": "zai",
      "think": true,
      "max_tokens": 65536
    },
    "small": {
      "model": "glm-4.7-flash",
      "provider": "zai"
    }
  },
  "lsp": {
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"]
    },
    "deno": {
      "command": "deno",
      "args": ["lsp"]
    },
    "bash": {
      "command": "bash-language-server",
      "args": ["start"]
    }
  }
}
